# Copy this file to the workspace root .env or to peopleops-intelligence/.env.
# Replace these placeholders with your real Worklogix API details.

WORKLOGIX_API_BASE_URL=PUT_WORKLOGIX_API_URL_HERE
WORKLOGIX_EMAIL=PUT_WORKLOGIX_EMAIL_HERE
WORKLOGIX_PASSWORD=PUT_WORKLOGIX_PASSWORD_HERE

# Optional: set this only if you already have a valid token and want to skip login.
WORKLOGIX_JWT_TOKEN=PUT_WORKLOGIX_JWT_TOKEN_HERE
